# ══════════════════════════════════════════════════════════════════════════════
# 知影 · AI读帖官 - Netlify 环境变量配置
# ══════════════════════════════════════════════════════════════════════════════
#
# 在 Netlify UI 中配置:
#   Site settings → Environment variables → Add a variable
#
# 或使用 Netlify CLI:
#   netlify env:set ZHIHU_CLIENT_ID your_client_id
#
# ══════════════════════════════════════════════════════════════════════════════

# ─── 知乎 OAuth2.0 ───
# 申请地址: https://open.zhihu.com/
# 回调地址需配置为: https://zhiying-web.netlify.app/auth/callback/
ZHIHU_CLIENT_ID=your_zhihu_client_id
ZHIHU_CLIENT_SECRET=your_zhihu_client_secret
ZHIHU_REDIRECT_URI=https://zhiying-web.netlify.app/auth/callback/

# ─── 微信开放平台 OAuth ───
# 申请地址: https://open.weixin.qq.com/
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# ─── GitHub OAuth ───
# 申请地址: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ─── JWT 密钥 ───
JWT_SECRET=your_random_jwt_secret_key_at_least_32_chars
